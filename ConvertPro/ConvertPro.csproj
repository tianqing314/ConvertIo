<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <RootNamespace>ConvertPro</RootNamespace>
    <AssemblyName>ConvertPro</AssemblyName>
    <StartupObject>ConvertPro.App</StartupObject>
  </PropertyGroup>

  <ItemGroup>
    <!-- WebView2 宿主 -->
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2903.40" />
    
    <!-- 文档格式处理 -->
    <PackageReference Include="DocumentFormat.OpenXml" Version="3.3.0" />
    
    <!-- PDF 读取 -->
    <PackageReference Include="PdfPig" Version="0.1.14" />
    
    <!-- PDF 生成 -->
    <PackageReference Include="QuestPDF" Version="2026.6.0" />
    
    <!-- Excel 读写 -->
    <PackageReference Include="ClosedXML" Version="0.105.0" />
    
    <!-- 图片处理（PNG→ICO 等） -->
    <PackageReference Include="System.Drawing.Common" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="wwwroot\**\*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
