<Window x:Class="ConvertPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"

        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"

        Title="ConvertPro"
        Width="1120"
        Height="760"
        MinWidth="900"
        MinHeight="600"

        Background="#F0F0F0">

    <!--
        ⚠️ 关键踩坑：禁用 AllowsTransparency！
        透明分层窗口会导致 WebView2 完全无法接收鼠标点击输入。
        必须使用与 HTML 同色的实色背景，因为 HTML 页面自身已有完整背景。
    -->

    <!-- 全窗口铺满 WebView2 控件 -->
    <wpf:WebView2 x:Name="webView"
                  DefaultBackgroundColor="#F0F0F0" />
</Window>
